# Скопируй этот файл в .env.local и подставь значения.

# --- PocketBase (основной бэкенд) ---
# Публичный адрес API PocketBase на российском хостинге (или локальный для разработки).
NEXT_PUBLIC_PB_URL=http://127.0.0.1:8090

# Учётка суперюзера PocketBase — только для скриптов (scripts/pb-setup.mjs,
# scripts/seed.mjs). В клиент НЕ попадает.
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=
