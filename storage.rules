rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Фото товаров: смотреть может кто угодно (витрина), загружать/удалять —
    // только админ (custom claim admin:true проставляется через Admin SDK).
    // Появление обычных пользователей доступ к записи им НЕ даёт.
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.admin == true
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Всё остальное — запрещено.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
