rules_version = '2';

// Каталог товаров: читать может кто угодно (нужно витрине),
// писать — только авторизованный администратор (Firebase Authentication).
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
