rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Админ — это пользователь, для которого есть документ в коллекции `admins`
    // с id, равным его UID.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /products/{productId} {
      allow read: if true;            // витрина доступна всем
      allow write: if isAdmin();      // править товары может только админ
    }

    // Заказы пользователя: владелец видит и пишет только свои.
    match /users/{uid}/orders/{orderId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /admins/{uid} {
      // Пользователь может прочитать только свою запись — чтобы клиент понял,
      // админ он или нет. Чужие записи и список целиком читать нельзя.
      allow read: if request.auth != null && request.auth.uid == uid;
      // Список админов редактируется только из консоли Firebase / Admin SDK.
      allow write: if false;
    }
  }
}
